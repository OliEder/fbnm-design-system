---
import ScoreSummary from '../ScoreSummary/ScoreSummary.astro'
import PeriodTable from '../PeriodTable/PeriodTable.astro'
import BoxScore from '../BoxScore/BoxScore.astro'
import LeagueStandings from '../LeagueStandings/LeagueStandings.astro'

// Re-export der Teil-Typen über die Props dieser Komponente.
type PeriodRow = {
  team: string
  scores: number[]
  total: number
  isFBNM?: boolean
}
type PlayerStat = {
  nr: number
  name: string
  pos?: string
  pts: number
  fgm: number
  ftm: number
  fta: number
  top?: boolean
  played?: boolean
}
type StandingRow = {
  rank: number
  team: string
  initials: string
  logoBg?: string
  games: number
  gp: number
  wins: number
  losses: number
  gb: string
  diff: number
  isFBNM?: boolean
}
type DetailItem = { label: string; value: string }

interface Props {
  // --- Hero ---
  title: string
  /** Tag/Monat/Jahr für das Datums-Kästchen */
  day: string
  month: string
  year: string
  /** Kategorie-Badges, z.B. ["Spielbericht", "Jugend · U10"] */
  tags?: string[]
  author?: string
  /** Meta-Zeile unter dem Titel, z.B. "Lesedauer 1 Min · U10 mixed Bezirksliga 2025/26" */
  byline?: string
  heroImage?: string

  // --- Score ---
  homeTeam: string
  awayTeam: string
  homeScore: number
  awayScore: number
  fbnmIsHome?: boolean
  /** Zusatz beim Gegner, z.B. "Auswärts · Spieltag 7" */
  scoreMeta?: string

  // --- Tabellen ---
  /** 'Achtel' (bis U12) oder 'Viertel' (ab U14) */
  mode?: 'Achtel' | 'Viertel'
  periods: PeriodRow[]
  players: PlayerStat[]
  coach?: string
  details: DetailItem[]
  standings: StandingRow[]
  /** Titel + Note der Liga-Tabelle */
  standingsTitle?: string
  standingsNote?: string

  class?: string
}

const {
  title,
  day,
  month,
  year,
  tags = [],
  author,
  byline,
  heroImage,
  homeTeam,
  awayTeam,
  homeScore,
  awayScore,
  fbnmIsHome = true,
  scoreMeta,
  mode = 'Achtel',
  periods,
  players,
  coach,
  details,
  standings,
  standingsTitle = 'Tabelle',
  standingsNote,
  class: className,
} = Astro.props
---

<article class:list={['fbnm-spielbericht', className]}>
  {/* HERO */}
  <header
    class="fbnm-spielbericht__hero"
    style={heroImage ? `--hero-bg: url(${heroImage})` : ''}
  >
    <div class="fbnm-spielbericht__hero-inner">
      <div class="fbnm-spielbericht__date" aria-hidden="true">
        <div class="fbnm-spielbericht__date-day">{day}</div>
        <div class="fbnm-spielbericht__date-month">{month}</div>
        <div class="fbnm-spielbericht__date-year">{year}</div>
      </div>
      <div class="fbnm-spielbericht__hero-text">
        {tags.length > 0 && (
          <div class="fbnm-spielbericht__tags">
            {tags.map((t, i) => (
              <span class:list={['fbnm-spielbericht__tag', i === 0 && 'fbnm-spielbericht__tag--primary']}>{t}</span>
            ))}
          </div>
        )}
        <h1 class="fbnm-spielbericht__title">{title}</h1>
        {(author || byline) && (
          <p class="fbnm-spielbericht__byline">
            {author && <>von <strong>{author}</strong>{byline && ' · '}</>}
            {byline}
          </p>
        )}
      </div>
    </div>
  </header>

  <div class="fbnm-spielbericht__body">
    <ScoreSummary
      homeTeam={homeTeam}
      awayTeam={awayTeam}
      homeScore={homeScore}
      awayScore={awayScore}
      fbnmIsHome={fbnmIsHome}
      meta={scoreMeta}
    />

    <PeriodTable rows={periods} mode={mode} />

    {/* Artikeltext kommt als Slot — beliebiges HTML vom Aufrufer */}
    <div class="fbnm-spielbericht__article">
      <slot />
    </div>

    <BoxScore players={players} title="Statistik · Fibalon Baskets Neumarkt" coach={coach} />

    {/* SPIELDETAILS */}
    <section class="fbnm-spielbericht__details">
      <h2 class="fbnm-spielbericht__section-title">Spieldetails</h2>
      <dl class="fbnm-spielbericht__details-grid">
        {details.map(d => (
          <div class="fbnm-spielbericht__detail">
            <dt class="fbnm-spielbericht__detail-label">{d.label}</dt>
            <dd class="fbnm-spielbericht__detail-value">{d.value}</dd>
          </div>
        ))}
      </dl>
    </section>

    <LeagueStandings
      rows={standings}
      title={standingsTitle}
      note={standingsNote}
    />
  </div>
</article>

<style>
.fbnm-spielbericht {
  font-family: var(--fbnm-font-body);
  color: var(--fbnm-color-text);
}

/* --- HERO --- */
.fbnm-spielbericht__hero {
  position: relative;
  background-color: var(--fbnm-blue-900);
  background-image: var(--hero-bg);
  background-size: cover;
  background-position: center 32%;
  background-repeat: no-repeat;
  min-height: 420px;
  display: flex;
  align-items: flex-end;
}

.fbnm-spielbericht__hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    0deg,
    color-mix(in srgb, var(--fbnm-blue-900) 96%, transparent) 8%,
    color-mix(in srgb, var(--fbnm-blue-900) 55%, transparent) 60%,
    color-mix(in srgb, var(--fbnm-blue-900) 35%, transparent) 100%
  );
}

.fbnm-spielbericht__hero::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--fbnm-cyan-500), var(--fbnm-cyan-400));
}

.fbnm-spielbericht__hero-inner {
  position: relative;
  z-index: 1;
  max-width: 900px;
  margin: 0 auto;
  width: 100%;
  padding: var(--fbnm-space-10) var(--fbnm-space-6);
  color: var(--fbnm-white);
  display: flex;
  gap: var(--fbnm-space-6);
  align-items: flex-end;
}

.fbnm-spielbericht__date {
  flex: none;
  text-align: center;
  background: color-mix(in srgb, var(--fbnm-white) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--fbnm-white) 25%, transparent);
  border-radius: var(--fbnm-radius-md);
  padding: var(--fbnm-space-3) var(--fbnm-space-4);
}
.fbnm-spielbericht__date-day {
  font-family: var(--fbnm-font-display);
  font-size: var(--fbnm-text-3xl);
  line-height: 1;
}
/* WCAG 1.4.3: cyan-400 auf blue-900-Hero ≈ 5.0:1 (AA). Großschrift-Label, brand. */
.fbnm-spielbericht__date-month {
  font-family: var(--fbnm-font-body);
  font-weight: 700;
  font-size: var(--fbnm-text-xs);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--fbnm-cyan-400);
  margin-top: 2px;
}
.fbnm-spielbericht__date-year {
  font-family: var(--fbnm-font-body);
  font-size: var(--fbnm-text-xs);
  color: color-mix(in srgb, var(--fbnm-white) 70%, transparent);
}

.fbnm-spielbericht__tags {
  display: flex;
  gap: var(--fbnm-space-2);
  margin-bottom: var(--fbnm-space-3);
  flex-wrap: wrap;
}
.fbnm-spielbericht__tag {
  padding: 4px var(--fbnm-space-3);
  border-radius: var(--fbnm-radius-full);
  font-family: var(--fbnm-font-body);
  font-weight: 700;
  font-size: var(--fbnm-text-xs);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  background: color-mix(in srgb, var(--fbnm-white) 15%, transparent);
  color: var(--fbnm-white);
}
/* WCAG 1.4.3: blue-900 auf cyan-500 = 5.1:1 (AA). Kleintext-Badge — primärer Tag. */
.fbnm-spielbericht__tag--primary {
  background: var(--fbnm-cyan-500);
  color: var(--fbnm-blue-900);
}

.fbnm-spielbericht__title {
  font-family: var(--fbnm-font-display);
  text-transform: uppercase;
  font-size: clamp(2rem, 6vw, var(--fbnm-text-5xl));
  line-height: 1.05;
  margin: 0;
  max-width: 18ch;
}

/* WCAG 1.4.6: white @ 75% auf blue-900-Hero ≈ 11:1 AAA */
.fbnm-spielbericht__byline {
  font-family: var(--fbnm-font-body);
  font-size: var(--fbnm-text-sm);
  color: color-mix(in srgb, var(--fbnm-white) 75%, transparent);
  margin-top: var(--fbnm-space-3);
}
.fbnm-spielbericht__byline strong { font-weight: 700; color: var(--fbnm-white); }

/* --- BODY --- */
.fbnm-spielbericht__body {
  max-width: 900px;
  margin: 0 auto;
  padding: var(--fbnm-space-10) var(--fbnm-space-6) var(--fbnm-space-20);
  display: flex;
  flex-direction: column;
  gap: var(--fbnm-space-10);
}

/* --- ARTICLE (Slot) --- */
.fbnm-spielbericht__article {
  font-size: var(--fbnm-text-lg);
  line-height: var(--fbnm-leading-normal);
  color: var(--fbnm-color-text);
}
.fbnm-spielbericht__article :global(p) { margin: 0 0 var(--fbnm-space-5); }
.fbnm-spielbericht__article :global(p:last-child) { margin-bottom: 0; }
.fbnm-spielbericht__article :global(strong) { font-weight: 700; }
.fbnm-spielbericht__article :global(blockquote) {
  margin: var(--fbnm-space-6) 0;
  padding: var(--fbnm-space-5) var(--fbnm-space-6);
  border-left: 4px solid var(--fbnm-cyan-500);
  background: color-mix(in srgb, var(--fbnm-blue-800) 8%, var(--fbnm-white));
  border-radius: 0 var(--fbnm-radius-md) var(--fbnm-radius-md) 0;
}
.fbnm-spielbericht__article :global(blockquote p) {
  font-style: italic;
  font-size: var(--fbnm-text-xl);
  line-height: var(--fbnm-leading-normal);
  color: var(--fbnm-blue-900);
  margin: 0;
}
/* WCAG 1.4.3: accent-text-Token (#005a87) = 7.55:1 AAA auf hellem BG */
.fbnm-spielbericht__article :global(blockquote footer),
.fbnm-spielbericht__article :global(blockquote cite) {
  display: block;
  margin-top: var(--fbnm-space-3);
  font-style: normal;
  font-weight: 700;
  font-size: var(--fbnm-text-sm);
  color: var(--fbnm-color-accent-text);
}

/* --- DETAILS --- */
.fbnm-spielbericht__section-title {
  font-family: var(--fbnm-font-display);
  text-transform: uppercase;
  font-size: var(--fbnm-text-2xl);
  color: var(--fbnm-blue-800);
  margin-bottom: var(--fbnm-space-3);
}

.fbnm-spielbericht__details-grid {
  background: var(--fbnm-white);
  border-radius: var(--fbnm-radius-md);
  overflow: hidden;
  box-shadow: var(--fbnm-shadow-sm);
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  margin: 0;
}
.fbnm-spielbericht__detail {
  padding: var(--fbnm-space-4) var(--fbnm-space-5);
  border-right: 1px solid var(--fbnm-color-border);
  border-bottom: 1px solid var(--fbnm-color-border);
}
.fbnm-spielbericht__detail-label {
  font-family: var(--fbnm-font-body);
  font-weight: 700;
  font-size: var(--fbnm-text-xs);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  /* WCAG 1.4.3: muted-text statt gray-500 */
  color: var(--fbnm-color-text-muted);
}
.fbnm-spielbericht__detail-value {
  font-family: var(--fbnm-font-body);
  font-weight: 700;
  font-size: var(--fbnm-text-base);
  color: var(--fbnm-color-text);
  margin: var(--fbnm-space-1) 0 0;
}

@media (max-width: 600px) {
  .fbnm-spielbericht__hero-inner { flex-direction: column; align-items: flex-start; }
}
</style>
