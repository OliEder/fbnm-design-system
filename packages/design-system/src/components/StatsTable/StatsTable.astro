---
interface Standing {
  rank: number
  team: string
  games: number
  wins: number
  losses: number
  pointsFor: number
  pointsAgainst: number
  points: number
  isFBNM?: boolean
}

interface Props {
  standings: Standing[]
  title?: string
  league?: string
}

const { standings, title = 'Tabelle', league } = Astro.props
---

<div class="fbnm-statstable">
  <header class="fbnm-statstable__header">
    <h2 class="fbnm-statstable__title">{title}</h2>
    {league && <span class="fbnm-statstable__league">{league}</span>}
  </header>
  <div class="fbnm-statstable__scroll">
    <table>
      <thead>
        <tr>
          <th scope="col">#</th>
          <th scope="col" class="fbnm-statstable__team-col">Team</th>
          <th scope="col">Sp</th>
          <th scope="col">S</th>
          <th scope="col">N</th>
          <th scope="col">Pkte</th>
          <th scope="col">Diff</th>
          <th scope="col" class="fbnm-statstable__pts-col">Pkt</th>
        </tr>
      </thead>
      <tbody>
        {standings.map(row => (
          <tr class:list={{ 'fbnm-statstable__row--highlight': row.isFBNM }}>
            <td class="fbnm-statstable__rank">{row.rank}</td>
            <td class="fbnm-statstable__team">
              {row.isFBNM && <span class="fbnm-statstable__fbnm-marker" aria-hidden="true">&#9679;</span>}
              {row.team}
            </td>
            <td>{row.games}</td>
            <td>{row.wins}</td>
            <td>{row.losses}</td>
            <td>{row.pointsFor}:{row.pointsAgainst}</td>
            <td>{row.pointsFor - row.pointsAgainst > 0 ? '+' : ''}{row.pointsFor - row.pointsAgainst}</td>
            <td class="fbnm-statstable__pts-col">{row.points}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
.fbnm-statstable {
  background: var(--fbnm-white);
  border-radius: var(--fbnm-radius-md);
  overflow: hidden;
  box-shadow: var(--fbnm-shadow-sm);
}

.fbnm-statstable__header {
  background: var(--fbnm-blue-800);
  color: var(--fbnm-white);
  padding: var(--fbnm-space-4) var(--fbnm-space-6);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.fbnm-statstable__title {
  font-family: var(--fbnm-font-display);
  font-size: var(--fbnm-text-xl);
  text-transform: uppercase;
}

.fbnm-statstable__league {
  font-family: var(--fbnm-font-caption);
  font-size: var(--fbnm-text-xs);
  color: var(--fbnm-cyan-400);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.fbnm-statstable__scroll { overflow-x: auto; }

table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--fbnm-text-sm);
}

thead th {
  background: color-mix(in srgb, var(--fbnm-blue-900) 5%, var(--fbnm-white));
  padding: var(--fbnm-space-2) var(--fbnm-space-3);
  font-family: var(--fbnm-font-caption);
  font-size: var(--fbnm-text-xs);
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--fbnm-blue-800);
  text-align: center;
  white-space: nowrap;
}

.fbnm-statstable__team-col,
.fbnm-statstable__team { text-align: left; }

tbody td {
  padding: var(--fbnm-space-3);
  text-align: center;
  border-bottom: 1px solid var(--fbnm-color-border);
  color: var(--fbnm-color-text);
}

tbody tr:last-child td { border-bottom: none; }

tbody tr:hover {
  background: color-mix(in srgb, var(--fbnm-blue-800) 5%, var(--fbnm-white));
}

.fbnm-statstable__row--highlight {
  background: color-mix(in srgb, var(--fbnm-cyan-500) 8%, var(--fbnm-white));
}
.fbnm-statstable__row--highlight td { font-weight: 700; }

.fbnm-statstable__rank {
  font-family: var(--fbnm-font-caption);
  font-weight: 600;
  color: var(--fbnm-blue-800);
}

.fbnm-statstable__team {
  display: flex;
  align-items: center;
  gap: var(--fbnm-space-2);
  white-space: nowrap;
}

.fbnm-statstable__fbnm-marker { color: var(--fbnm-cyan-500); font-size: 0.5rem; }

.fbnm-statstable__pts-col {
  font-family: var(--fbnm-font-display);
  font-weight: 700;
  color: var(--fbnm-blue-800);
}
</style>
