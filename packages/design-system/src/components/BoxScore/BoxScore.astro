---
interface PlayerStat {
  nr: number
  name: string
  /** Position (für Aufstellung) */
  pos?: string
  pts: number
  /** Field Goals Made */
  fgm: number
  /** Free Throws Made */
  ftm: number
  /** Free Throw Attempts */
  fta: number
  /** Hebt den Top-Scorer hervor */
  top?: boolean
  /** Spieler war im Einsatz (Aufstellung) */
  played?: boolean
}

interface Props {
  players: PlayerStat[]
  title?: string
  /** Coach-Name in der Fußzeile */
  coach?: string
  class?: string
}

const {
  players,
  title = 'Statistik',
  coach,
  class: className,
} = Astro.props

const totals = players.reduce(
  (acc, p) => ({
    pts: acc.pts + p.pts,
    fgm: acc.fgm + p.fgm,
    ftm: acc.ftm + p.ftm,
    fta: acc.fta + p.fta,
  }),
  { pts: 0, fgm: 0, ftm: 0, fta: 0 },
)

// Eindeutige ID, damit mehrere BoxScore-Instanzen pro Seite koexistieren können.
const uid = `fbnm-bs-${Math.random().toString(36).slice(2, 9)}`
---

<section class:list={['fbnm-boxscore', className]} data-boxscore>
  <h2 class="fbnm-boxscore__title">{title}</h2>
  <div class="fbnm-boxscore__card">
    <div role="tablist" aria-label="Statistik-Ansicht" class="fbnm-boxscore__tabs">
      <button
        role="tab"
        id={`${uid}-tab-stats`}
        aria-controls={`${uid}-panel-stats`}
        aria-selected="true"
        class="fbnm-boxscore__tab"
        data-tab="stats"
      >Spielerstatistik</button>
      <button
        role="tab"
        id={`${uid}-tab-lineup`}
        aria-controls={`${uid}-panel-lineup`}
        aria-selected="false"
        tabindex="-1"
        class="fbnm-boxscore__tab"
        data-tab="lineup"
      >Aufstellung</button>
    </div>

    {/* Panel: Spielerstatistik */}
    <div
      role="tabpanel"
      id={`${uid}-panel-stats`}
      aria-labelledby={`${uid}-tab-stats`}
      class="fbnm-boxscore__panel"
      data-panel="stats"
    >
      <div class="fbnm-boxscore__scroll">
        <table>
          <thead>
            <tr>
              <th scope="col" class="fbnm-boxscore__nr-col">#</th>
              <th scope="col" class="fbnm-boxscore__name-col">Spieler</th>
              <th scope="col" title="Punkte">PTS</th>
              <th scope="col" title="Field Goals Made">FGM</th>
              <th scope="col" title="Free Throws Made">FTM</th>
              <th scope="col" title="Free Throw Attempts">FTA</th>
            </tr>
          </thead>
          <tbody>
            {players.map(p => (
              <tr class:list={{ 'fbnm-boxscore__row--top': p.top }}>
                <td class="fbnm-boxscore__nr">{p.nr}</td>
                <td class="fbnm-boxscore__name">{p.name}</td>
                <td class="fbnm-boxscore__pts">{p.pts}</td>
                <td class="fbnm-boxscore__num">{p.fgm}</td>
                <td class="fbnm-boxscore__num">{p.ftm}</td>
                <td class="fbnm-boxscore__num">{p.fta}</td>
              </tr>
            ))}
            <tr class="fbnm-boxscore__total-row">
              <td></td>
              <td class="fbnm-boxscore__total-label">Gesamt</td>
              <td class="fbnm-boxscore__pts">{totals.pts}</td>
              <td class="fbnm-boxscore__total-num">{totals.fgm}</td>
              <td class="fbnm-boxscore__total-num">{totals.ftm}</td>
              <td class="fbnm-boxscore__total-num">{totals.fta}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    {/* Panel: Aufstellung */}
    <div
      role="tabpanel"
      id={`${uid}-panel-lineup`}
      aria-labelledby={`${uid}-tab-lineup`}
      class="fbnm-boxscore__panel"
      data-panel="lineup"
      hidden
    >
      <div class="fbnm-boxscore__scroll">
        <table>
          <thead>
            <tr>
              <th scope="col" class="fbnm-boxscore__nr-col">#</th>
              <th scope="col" class="fbnm-boxscore__name-col">Spieler</th>
              <th scope="col" class="fbnm-boxscore__name-col">Position</th>
              <th scope="col" class="fbnm-boxscore__played-col">Eingesetzt</th>
            </tr>
          </thead>
          <tbody>
            {players.map(p => (
              <tr class:list={{ 'fbnm-boxscore__row--top': p.top }}>
                <td class="fbnm-boxscore__nr">{p.nr}</td>
                <td class="fbnm-boxscore__name">{p.name}</td>
                <td class="fbnm-boxscore__pos">{p.pos ?? '–'}</td>
                <td class="fbnm-boxscore__played">
                  {p.played !== false ? (
                    <>
                      <span aria-hidden="true">&#10003;</span>
                      <span class="sr-only">eingesetzt</span>
                    </>
                  ) : (
                    <span class="sr-only">nicht eingesetzt</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    {coach && (
      <div class="fbnm-boxscore__footer">Coach: <strong>{coach}</strong></div>
    )}
  </div>
</section>

<style>
.fbnm-boxscore__title {
  font-family: var(--fbnm-font-display);
  text-transform: uppercase;
  font-size: var(--fbnm-text-2xl);
  color: var(--fbnm-blue-800);
  margin-bottom: var(--fbnm-space-3);
}

.fbnm-boxscore__card {
  background: var(--fbnm-white);
  border-radius: var(--fbnm-radius-md);
  overflow: hidden;
  box-shadow: var(--fbnm-shadow-sm);
}

.fbnm-boxscore__tabs {
  display: flex;
  gap: var(--fbnm-space-1);
  padding: 0 var(--fbnm-space-4);
  border-bottom: 2px solid var(--fbnm-color-border);
}

/* WCAG 1.4.3: inaktiver Tab nutzt muted-text (#545454, 7.14:1 AAA),
   aktiver Tab blue-800 (10.3:1 AAA). Auswahl wird zusätzlich durch
   den Unterstrich (nicht nur Farbe) signalisiert (1.4.1). */
.fbnm-boxscore__tab {
  background: none;
  border: none;
  cursor: pointer;
  padding: var(--fbnm-space-3) var(--fbnm-space-4);
  margin-bottom: -2px;
  font-family: var(--fbnm-font-body);
  font-size: var(--fbnm-text-sm);
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--fbnm-color-text-muted);
  border-bottom: 3px solid transparent;
  transition: color var(--fbnm-transition-fast),
              border-color var(--fbnm-transition-fast);
}

.fbnm-boxscore__tab:hover { color: var(--fbnm-blue-800); }

.fbnm-boxscore__tab[aria-selected='true'] {
  color: var(--fbnm-blue-800);
  font-weight: 700;
  border-bottom-color: var(--fbnm-cyan-500);
}

/* WCAG 2.4.7: sichtbarer Fokus */
.fbnm-boxscore__tab:focus-visible {
  outline: 2px solid var(--fbnm-blue-700);
  outline-offset: -2px;
  border-radius: var(--fbnm-radius-sm);
}

.fbnm-boxscore__panel[hidden] { display: none; }

.fbnm-boxscore__scroll { overflow-x: auto; }

table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--fbnm-font-body);
  font-size: var(--fbnm-text-sm);
}

thead th {
  background: color-mix(in srgb, var(--fbnm-blue-900) 5%, var(--fbnm-white));
  padding: var(--fbnm-space-2) var(--fbnm-space-3);
  font-family: var(--fbnm-font-body);
  font-weight: 700;
  font-size: var(--fbnm-text-xs);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--fbnm-blue-800);
  text-align: center;
  white-space: nowrap;
}

.fbnm-boxscore__nr-col { width: 48px; }
.fbnm-boxscore__name-col { text-align: left; }
.fbnm-boxscore__played-col { width: 96px; }

tbody td {
  padding: var(--fbnm-space-3);
  text-align: center;
  border-bottom: 1px solid var(--fbnm-color-border);
  color: var(--fbnm-color-text);
}

.fbnm-boxscore__nr {
  font-family: var(--fbnm-font-display);
  color: var(--fbnm-blue-800);
}

.fbnm-boxscore__name { text-align: left; }

.fbnm-boxscore__pts {
  font-family: var(--fbnm-font-display);
  font-size: var(--fbnm-text-base);
  color: var(--fbnm-blue-800);
  font-variant-numeric: tabular-nums;
}

.fbnm-boxscore__num { font-variant-numeric: tabular-nums; }

/* WCAG 1.4.3: Position als muted-text (#545454, 7.14:1 AAA) statt gray-500 (4.0:1 FAIL) */
.fbnm-boxscore__pos { text-align: left; color: var(--fbnm-color-text-muted); }

/* WCAG 1.4.1: Häkchen + sr-only-Text statt nur Farbe.
   #14532d (dunkelgrün) auf weiß = 8.7:1 AAA */
.fbnm-boxscore__played { color: #14532d; font-weight: 700; }

/* WCAG 1.4.1: Top-Scorer = Hintergrund + Fettung (nicht nur Farbe) */
.fbnm-boxscore__row--top {
  background: color-mix(in srgb, var(--fbnm-cyan-500) 8%, var(--fbnm-white));
}
.fbnm-boxscore__row--top .fbnm-boxscore__name { font-weight: 700; }

.fbnm-boxscore__total-row {
  background: color-mix(in srgb, var(--fbnm-blue-900) 7%, var(--fbnm-white));
}
.fbnm-boxscore__total-row td { border-bottom: none; }

.fbnm-boxscore__total-label {
  text-align: left;
  font-family: var(--fbnm-font-body);
  font-weight: 700;
  font-size: var(--fbnm-text-xs);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--fbnm-blue-800);
}

.fbnm-boxscore__total-num {
  font-family: var(--fbnm-font-display);
  color: var(--fbnm-blue-800);
  font-variant-numeric: tabular-nums;
}

.fbnm-boxscore__footer {
  padding: var(--fbnm-space-3) var(--fbnm-space-4);
  font-family: var(--fbnm-font-body);
  font-size: var(--fbnm-text-sm);
  color: var(--fbnm-color-text-muted);
  border-top: 1px solid var(--fbnm-color-border);
}
.fbnm-boxscore__footer strong { color: var(--fbnm-color-text); font-weight: 700; }

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}
</style>

<script>
// Tab-Steuerung mit WAI-ARIA Tabs-Pattern (Pfeiltasten + Home/End).
// Mehrere Instanzen pro Seite werden unabhängig gesteuert.
function initBoxScore(root: HTMLElement): void {
  const tabs = Array.from(
    root.querySelectorAll<HTMLButtonElement>('[role="tab"]'),
  )
  const panels = new Map<string, HTMLElement>()
  root.querySelectorAll<HTMLElement>('[data-panel]').forEach(p => {
    panels.set(p.dataset.panel!, p)
  })

  function select(tab: HTMLButtonElement): void {
    tabs.forEach(t => {
      const selected = t === tab
      t.setAttribute('aria-selected', String(selected))
      t.tabIndex = selected ? 0 : -1
    })
    panels.forEach((panel, key) => {
      panel.hidden = key !== tab.dataset.tab
    })
  }

  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => select(tab))
    tab.addEventListener('keydown', e => {
      let next = -1
      if (e.key === 'ArrowRight') next = (i + 1) % tabs.length
      else if (e.key === 'ArrowLeft') next = (i - 1 + tabs.length) % tabs.length
      else if (e.key === 'Home') next = 0
      else if (e.key === 'End') next = tabs.length - 1
      if (next === -1) return
      e.preventDefault()
      tabs[next].focus()
      select(tabs[next])
    })
  })
}

document
  .querySelectorAll<HTMLElement>('[data-boxscore]')
  .forEach(initBoxScore)
</script>
