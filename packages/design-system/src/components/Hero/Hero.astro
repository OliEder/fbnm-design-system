---
interface Props {
  title: string
  subtitle?: string
  backgroundImage?: string
  class?: string
}

const { title, subtitle, backgroundImage, class: className } = Astro.props
---

<section
  class:list={['fbnm-hero', className]}
  style={backgroundImage ? `--hero-bg: url(${backgroundImage})` : ''}
>
  <div class="fbnm-hero__inner">
    <h1 class="fbnm-hero__title">{title}</h1>
    {subtitle && <p class="fbnm-hero__subtitle">{subtitle}</p>}
    <div class="fbnm-hero__actions">
      <slot />
    </div>
  </div>
</section>

<style>
.fbnm-hero {
  position: relative;
  min-height: 60vh;
  display: flex;
  align-items: center;
  background-color: var(--fbnm-blue-900);
  background-image: var(--hero-bg);
  background-size: cover;
  background-position: center;
  overflow: hidden;
}

.fbnm-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    color-mix(in srgb, var(--fbnm-blue-900) 85%, transparent),
    color-mix(in srgb, var(--fbnm-blue-800) 60%, transparent)
  );
}

.fbnm-hero::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--fbnm-cyan-500), var(--fbnm-cyan-400));
}

.fbnm-hero__inner {
  position: relative;
  z-index: 1;
  max-width: var(--fbnm-container-max);
  margin: 0 auto;
  padding: var(--fbnm-space-20) var(--fbnm-container-padding);
}

.fbnm-hero__title {
  color: var(--fbnm-white);
  font-family: var(--fbnm-font-display);
  font-size: clamp(2.5rem, 8vw, var(--fbnm-text-6xl));
  text-transform: uppercase;
  line-height: 1;
  max-width: 16ch;
}

/* WCAG 1.4.6 AAA: cyan-400 on blue-900 overlay = 5.67:1 (AA only) → white = 21:1 (AAA) */
.fbnm-hero__subtitle {
  color: var(--fbnm-white);
  font-family: var(--fbnm-font-caption);
  font-size: var(--fbnm-text-xl);
  margin-top: var(--fbnm-space-4);
  font-weight: 300;
  opacity: 0.9;
}

.fbnm-hero__actions {
  margin-top: var(--fbnm-space-8);
  display: flex;
  gap: var(--fbnm-space-4);
  flex-wrap: wrap;
}

/* WCAG 1.4.3 AAA: Ghost-Button (blue-800 on white) wird im Hero-Kontext (blue-900 bg)
   zu weiß geändert — blue-800 auf blue-900 = 1.43:1 (FAIL).
   Weißer Text + Border auf blue-900 = 21:1 AAA. */
/* Specificity (0,3,0) beats Button's scoped (0,2,0) — both classes always present on ghost buttons */
:global(.fbnm-hero .fbnm-btn.fbnm-btn--ghost) {
  color: var(--fbnm-white);
  border-color: var(--fbnm-white);
}
:global(.fbnm-hero .fbnm-btn.fbnm-btn--ghost:hover:not(:disabled)) {
  background-color: rgba(255, 255, 255, 0.12);
  color: var(--fbnm-white);
  border-color: var(--fbnm-white);
}
:global(.fbnm-hero .fbnm-btn.fbnm-btn--ghost:focus-visible) {
  outline-color: var(--fbnm-white);
}
</style>
