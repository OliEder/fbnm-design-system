---
import '@ds/styles/index.css'

interface Props {
  title: string
}

const { title } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const navSections = [
  {
    label: 'Einführung',
    links: [{ label: 'Übersicht', href: '/' }],
  },
  {
    label: 'Design Tokens',
    links: [
      { label: 'Farben', href: '/tokens/' },
      { label: 'Typografie', href: '/tokens/typografie/' },
      { label: 'Abstände', href: '/tokens/abstaende/' },
    ],
  },
  {
    label: 'Atome',
    links: [
      { label: 'Button', href: '/atome/button/' },
      { label: 'Badge', href: '/atome/badge/' },
      { label: 'Card', href: '/atome/card/' },
    ],
  },
  {
    label: 'Komponenten',
    links: [
      { label: 'Navigation', href: '/komponenten/navigation/' },
      { label: 'Hero', href: '/komponenten/hero/' },
      { label: 'Footer', href: '/komponenten/footer/' },
      { label: 'GameCard', href: '/komponenten/gamecard/' },
      { label: 'Spielplan', href: '/komponenten/spielplan/' },
      { label: 'PlayerCard', href: '/komponenten/playercard/' },
      { label: 'StatsTable', href: '/komponenten/statstable/' },
      { label: 'LiveTicker', href: '/komponenten/liveticker/' },
    ],
  },
  {
    label: 'Seiten',
    links: [
      { label: 'Startseite', href: '/seiten/' },
      { label: 'Spielbericht', href: '/seiten/spielbericht/' },
      { label: 'Übersicht (Club-Hub)', href: '/seiten/uebersicht/' },
      { label: 'Team-Seite', href: '/seiten/team-seite/' },
    ],
  },
]

const currentPath = Astro.url.pathname
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} – FBNM Design System</title>
  <meta name="description" content="FBNM Design System Dokumentation – Fibalon Baskets Neumarkt" />
  <meta name="robots" content="noindex" />
  <style is:global>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { box-sizing: border-box; }

    .docs-body {
      margin: 0;
      font-family: var(--fbnm-font-body, system-ui, sans-serif);
      background: #f0f4f8;
      color: #1e293b;
      font-size: 16px;
      line-height: 1.6;
    }

    /* ===== SKIP LINK ===== */
    .docs-skip {
      position: absolute;
      top: -100px;
      left: 1rem;
      background: var(--fbnm-cyan-500, #009fe3);
      color: #fff;
      padding: 0.5rem 1rem;
      text-decoration: none;
      font-size: 0.875rem;
      z-index: 9999;
      border-radius: 0 0 6px 6px;
    }
    .docs-skip:focus { top: 0; }

    /* ===== LAYOUT ===== */
    .docs-layout {
      display: grid;
      grid-template-columns: 260px 1fr;
      min-height: 100vh;
    }

    /* ===== SIDEBAR ===== */
    .docs-sidebar {
      background: var(--fbnm-blue-900, #002751);
      color: #fff;
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }

    .docs-brand {
      padding: 1.25rem;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      flex-shrink: 0;
    }
    .docs-brand__link {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: inherit;
    }
    .docs-brand__link:focus-visible {
      outline: 2px solid var(--fbnm-cyan-500, #009fe3);
      outline-offset: 2px;
      border-radius: 4px;
    }
    .docs-brand__icon { font-size: 1.75rem; line-height: 1; }
    .docs-brand__name {
      display: block;
      font-family: var(--fbnm-font-display, sans-serif);
      font-size: 1.2rem;
      text-transform: uppercase;
      line-height: 1;
      letter-spacing: 0.05em;
    }
    .docs-brand__sub {
      display: block;
      font-family: var(--fbnm-font-caption, sans-serif);
      font-size: 0.625rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      /* rgba(255,255,255,0.6) on #002751 → ~6.0:1 (WCAG AA) */
      color: rgba(255,255,255,0.6);
      margin-top: 3px;
    }

    .docs-nav {
      list-style: none;
      margin: 0;
      padding: 0.75rem 0;
      flex: 1;
      overflow-y: auto;
    }

    .docs-nav__section { margin-bottom: 0.125rem; }

    .docs-nav__group-label {
      display: block;
      font-family: var(--fbnm-font-caption, sans-serif);
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      /* rgba(255,255,255,0.65) on #002751 → ~7.2:1 (WCAG AAA) */
      color: rgba(255,255,255,0.65);
      padding: 0.875rem 1.25rem 0.25rem;
    }

    .docs-nav__group {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .docs-nav__link {
      display: block;
      padding: 0.35rem 1.25rem;
      text-decoration: none;
      font-family: var(--fbnm-font-body, sans-serif);
      font-size: 0.875rem;
      color: rgba(255,255,255,0.7);
      border-left: 2px solid transparent;
      transition: color 0.15s, background 0.15s, border-color 0.15s;
    }
    .docs-nav__link:hover {
      color: #fff;
      background: rgba(255,255,255,0.06);
    }
    .docs-nav__link--active {
      color: #fff;
      border-left-color: var(--fbnm-cyan-500, #009fe3);
      background: rgba(0,159,227,0.14);
      font-weight: 600;
    }
    .docs-nav__link:focus-visible {
      outline: 2px solid var(--fbnm-cyan-500, #009fe3);
      outline-offset: -2px;
    }

    .docs-sidebar__footer {
      padding: 0.75rem 1.25rem;
      border-top: 1px solid rgba(255,255,255,0.1);
      flex-shrink: 0;
    }
    .docs-version {
      font-family: var(--fbnm-font-caption, sans-serif);
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      /* rgba(255,255,255,0.55) on #002751 → ~5.7:1 (WCAG AA) */
      color: rgba(255,255,255,0.55);
    }

    /* ===== MAIN ===== */
    .docs-main { overflow-x: hidden; min-width: 0; }
    .docs-main:focus { outline: none; }

    /* ===== PAGE ===== */
    .docs-page {
      max-width: 860px;
      margin: 0 auto;
      padding: 3rem 2.5rem;
    }

    .docs-page__header {
      margin-bottom: 2.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid #dde3ec;
    }

    .docs-page__breadcrumb {
      font-family: var(--fbnm-font-caption, sans-serif);
      font-size: 0.7rem;
      /* #546372 on #f0f4f8 → 5.6:1 (WCAG AA) */
      color: #546372;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
    }

    .docs-page__title {
      font-family: var(--fbnm-font-display, sans-serif);
      font-size: 2.25rem;
      text-transform: uppercase;
      color: var(--fbnm-blue-800, #004174);
      margin: 0 0 0.75rem;
      line-height: 1.1;
    }

    .docs-page__desc {
      font-size: 1rem;
      color: #475569;
      line-height: 1.7;
      max-width: 62ch;
      margin: 0;
    }

    h2.docs-heading {
      font-family: var(--fbnm-font-display, sans-serif);
      font-size: 1.375rem;
      text-transform: uppercase;
      color: var(--fbnm-blue-800, #004174);
      margin: 2.5rem 0 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid #e2e8f0;
    }

    /* ===== DEMO ===== */
    .demo {
      border: 1px solid #dde3ec;
      border-radius: 8px;
      overflow: hidden;
      margin: 1rem 0;
    }
    .demo__label {
      background: #f8fafc;
      border-bottom: 1px solid #dde3ec;
      padding: 0.35rem 0.75rem;
      font-family: var(--fbnm-font-caption, sans-serif);
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      /* #546372 on #f8fafc → 5.9:1 (WCAG AA) */
      color: #546372;
    }
    .demo__canvas {
      padding: 2rem;
      background: #fff;
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: flex-start;
    }
    .demo__canvas--dark  { background: var(--fbnm-blue-800, #004174); }
    .demo__canvas--navy  { background: var(--fbnm-blue-900, #002751); }
    .demo__canvas--gray  { background: #f0f4f8; }
    .demo__canvas--full  { padding: 0; display: block; }
    .demo__canvas--grid  {
      padding: 2rem;
      background: #fff;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
    }

    /* ===== CODE ===== */
    .code-block {
      background: #0f172a;
      border-radius: 6px;
      overflow-x: auto;
      padding: 1rem 1.25rem;
      margin: 0.75rem 0 1.5rem;
    }
    .code-block pre {
      margin: 0;
      font-family: 'Fira Code', 'Cascadia Code', 'Courier New', monospace;
      font-size: 0.8125rem;
      line-height: 1.7;
      color: #e2e8f0;
      white-space: pre;
    }

    /* ===== COLOR PALETTE ===== */
    .color-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      gap: 0.625rem;
      margin: 1rem 0;
    }
    .color-chip {
      border-radius: 6px;
      overflow: hidden;
      border: 1px solid rgba(0,0,0,0.08);
    }
    .color-chip__swatch { height: 64px; }
    .color-chip__info {
      background: #fff;
      padding: 0.5rem 0.625rem;
    }
    .color-chip__name {
      display: block;
      font-family: monospace;
      font-size: 0.7rem;
      font-weight: 700;
      color: #1e293b;
    }
    .color-chip__hex {
      display: block;
      font-family: monospace;
      font-size: 0.675rem;
      color: #64748b;
      margin-top: 1px;
    }
    .color-chip__ratio {
      display: block;
      font-size: 0.625rem;
      margin-top: 3px;
      font-family: var(--fbnm-font-caption, sans-serif);
    }
    /* contrast on #dcfce7/#fef3c7/#fee2e2 chip backgrounds */
    .color-chip__ratio--aaa  { color: #14532d; } /* 7.3:1 on #dcfce7 */
    .color-chip__ratio--aa   { color: #92400e; } /* 5.2:1 on #fef3c7 */
    .color-chip__ratio--fail { color: #b91c1c; } /* 5.3:1 on #fee2e2 ✓ */

    /* ===== TYPESCALE ===== */
    .type-row {
      display: flex;
      align-items: baseline;
      gap: 1.25rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid #f1f5f9;
    }
    .type-row__meta {
      min-width: 8rem;
      flex-shrink: 0;
    }
    .type-row__token {
      display: block;
      font-family: monospace;
      font-size: 0.7rem;
      color: var(--fbnm-blue-800, #004174);
    }
    .type-row__size {
      display: block;
      font-size: 0.625rem;
      /* #546372 on #f0f4f8 → 5.6:1 (WCAG AA) */
      color: #546372;
      margin-top: 2px;
    }
    .type-row__sample { color: #1e293b; }

    /* ===== SPACING ===== */
    .space-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.45rem 0;
      border-bottom: 1px solid #f1f5f9;
    }
    .space-row__label {
      font-family: monospace;
      font-size: 0.7rem;
      color: var(--fbnm-blue-800, #004174);
      min-width: 7rem;
    }
    .space-row__bar {
      height: 8px;
      background: var(--fbnm-blue-800, #004174);
      border-radius: 2px;
      flex-shrink: 0;
    }
    .space-row__value {
      font-family: monospace;
      font-size: 0.675rem;
      /* #546372 on #f0f4f8 → 5.6:1 (WCAG AA) */
      color: #546372;
    }

    /* ===== WCAG CALLOUT ===== */
    .wcag {
      display: flex;
      gap: 0.625rem;
      align-items: flex-start;
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-left: 4px solid #16a34a;
      border-radius: 6px;
      padding: 0.75rem 1rem;
      margin: 1rem 0;
      font-size: 0.875rem;
      color: #14532d;
      line-height: 1.55;
    }
    .wcag--warn {
      background: #fffbeb;
      border-color: #fde68a;
      border-left-color: #d97706;
      color: #78350f;
    }
    .wcag--info {
      background: #eff6ff;
      border-color: #bfdbfe;
      border-left-color: #2563eb;
      color: #1e3a8a;
    }
    .wcag__icon { font-size: 1rem; flex-shrink: 0; margin-top: 0.1em; }

    /* ===== PROPS TABLE ===== */
    .props-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
      margin: 0.75rem 0 1.5rem;
    }
    .props-table th {
      text-align: left;
      font-family: var(--fbnm-font-caption, sans-serif);
      font-size: 0.625rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #64748b;
      padding: 0.5rem 0.75rem;
      border-bottom: 2px solid #e2e8f0;
      background: #f8fafc;
    }
    .props-table td {
      padding: 0.5rem 0.75rem;
      border-bottom: 1px solid #f1f5f9;
      vertical-align: top;
      color: #334155;
    }
    .props-table td:first-child {
      font-family: monospace;
      font-size: 0.8rem;
      color: var(--fbnm-blue-800, #004174);
      font-weight: 600;
    }
    .props-table td:nth-child(2) {
      font-family: monospace;
      font-size: 0.8rem;
      color: #7c3aed;
    }
    .props-table td:nth-child(3) {
      font-family: monospace;
      font-size: 0.8rem;
      /* #14532d on #f0f4f8 → 7.2:1 (WCAG AAA) */
      color: #14532d;
    }
    .props-table tr:last-child td { border-bottom: none; }

    /* ===== CONTRAST TABLE ===== */
    .contrast-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
      margin: 0.75rem 0 1.5rem;
    }
    .contrast-table th {
      text-align: left;
      font-family: var(--fbnm-font-caption, sans-serif);
      font-size: 0.625rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #64748b;
      padding: 0.5rem 0.75rem;
      border-bottom: 2px solid #e2e8f0;
      background: #f8fafc;
    }
    .contrast-table td {
      padding: 0.5rem 0.75rem;
      border-bottom: 1px solid #f1f5f9;
      vertical-align: middle;
      color: #334155;
      font-size: 0.875rem;
    }
    .contrast-table td:first-child {
      font-family: monospace;
      font-size: 0.8rem;
    }
    .contrast-table tr:last-child td { border-bottom: none; }

    .badge-level {
      display: inline-block;
      font-family: var(--fbnm-font-caption, sans-serif);
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 0.15em 0.5em;
      border-radius: 3px;
      font-weight: 700;
    }
    .badge-level--aaa  { background: #dcfce7; color: #14532d; }
    .badge-level--aa   { background: #fef3c7; color: #78350f; }
    .badge-level--fail { background: #fee2e2; color: #991b1b; }
    .badge-level--deco { background: #e0f2fe; color: #0369a1; }

    /* ===== INTRO CARDS ===== */
    .intro-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(185px, 1fr));
      gap: 1rem;
      margin: 1.5rem 0;
    }
    .intro-card {
      background: #fff;
      border: 1px solid #dde3ec;
      border-radius: 8px;
      padding: 1.25rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s, box-shadow 0.15s;
      display: block;
    }
    .intro-card:hover {
      border-color: var(--fbnm-blue-800, #004174);
      box-shadow: 0 4px 12px rgba(0,65,116,0.1);
    }
    .intro-card:focus-visible {
      outline: 2px solid var(--fbnm-cyan-500, #009fe3);
      outline-offset: 2px;
    }
    .intro-card__icon { font-size: 1.75rem; margin-bottom: 0.5rem; }
    .intro-card__title {
      font-family: var(--fbnm-font-display, sans-serif);
      font-size: 0.95rem;
      text-transform: uppercase;
      color: var(--fbnm-blue-800, #004174);
      margin: 0 0 0.3rem;
    }
    .intro-card__desc {
      font-size: 0.8125rem;
      color: #64748b;
      line-height: 1.45;
      margin: 0;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 800px) {
      .docs-layout { grid-template-columns: 1fr; }
      .docs-sidebar { position: static; height: auto; }
      .docs-page { padding: 1.5rem 1.25rem; }
    }
  </style>
</head>
<body class="docs-body">
  <a class="docs-skip" href="#docs-main">Zum Hauptinhalt springen</a>

  <div class="docs-layout">
    <nav class="docs-sidebar" aria-label="Design System Navigation">
      <div class="docs-brand">
        <a href={base + '/'} class="docs-brand__link">
          <span class="docs-brand__icon" aria-hidden="true">🏀</span>
          <div>
            <span class="docs-brand__name">FBNM</span>
            <span class="docs-brand__sub">Design System</span>
          </div>
        </a>
      </div>

      <ul class="docs-nav" role="list">
        {navSections.map(section => (
          <li class="docs-nav__section">
            <span class="docs-nav__group-label">{section.label}</span>
            <ul class="docs-nav__group" role="list">
              {section.links.map(link => {
                const href = base + link.href
                const isRoot = link.href === '/' && (currentPath === base + '/' || currentPath === base)
                const isActive = isRoot || (link.href !== '/' && currentPath.startsWith(base + link.href.replace(/\/$/, '')))
                return (
                  <li>
                    <a
                      href={href}
                      class:list={['docs-nav__link', { 'docs-nav__link--active': isActive }]}
                      aria-current={isActive ? 'page' : undefined}
                    >
                      {link.label}
                    </a>
                  </li>
                )
              })}
            </ul>
          </li>
        ))}
      </ul>

      <div class="docs-sidebar__footer">
        <span class="docs-version">v0.1.0 · WCAG 2.2 AA/AAA</span>
      </div>
    </nav>

    <main id="docs-main" class="docs-main" tabindex="-1">
      <slot />
    </main>
  </div>
</body>
</html>
