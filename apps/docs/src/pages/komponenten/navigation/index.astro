---
import DocsLayout from '../../../layouts/DocsLayout.astro'
import Navigation from '@ds/components/Navigation/Navigation.astro'

const links = [
  { label: 'Startseite', href: '#' },
  { label: 'Spielplan', href: '#', active: true },
  { label: 'Tabelle', href: '#' },
  { label: 'Team', href: '#' },
  { label: 'News', href: '#' },
]
---

<DocsLayout title="Navigation">
  <div class="docs-page">
    <header class="docs-page__header">
      <p class="docs-page__breadcrumb">Komponenten</p>
      <h1 class="docs-page__title">Navigation</h1>
      <p class="docs-page__desc">
        Responsive Hauptnavigation mit FBNM-Branding. Desktop: horizontale Link-Leiste.
        Mobile: Hamburger-Menü mit Overlay. Aktiver Link durch Farbe <strong>und</strong>
        Unterstrich erkennbar (WCAG 1.4.1).
      </p>
    </header>

    <div class="wcag">
      <span class="wcag__icon">✅</span>
      <span>
        Aktiver Link: weiße Schrift + <code>border-bottom: 2px solid white</code>
        (WCAG 1.4.1 — nicht nur durch Farbe) ·
        Hamburger-Button: 44×44 px (WCAG 2.5.5 AAA) ·
        Alle Links mit sichtbarem Fokusrahmen (2.4.11).
      </span>
    </div>

    <h2 class="docs-heading">Live-Demo</h2>
    <div class="demo">
      <div class="demo__label">Navigation (interaktiv)</div>
      <div class="demo__canvas demo__canvas--full">
        <Navigation links={links} currentTeam="Herren 1" />
      </div>
    </div>

    <h2 class="docs-heading">Verwendung</h2>
    <div class="code-block">
      <pre set:text={`---
import Navigation from '@fbnm/design-system/components/Navigation/Navigation.astro'

const links = [
  { label: 'Startseite', href: '/' },
  { label: 'Spielplan',  href: '/spielplan/', active: true },
  { label: 'Tabelle',    href: '/tabelle/' },
  { label: 'Team',       href: '/team/' },
  { label: 'News',       href: '/news/' },
]
---

<Navigation links={links} currentTeam="Herren 1" />`} />
    </div>

    <h2 class="docs-heading">Props</h2>
    <table class="props-table">
      <thead>
        <tr><th>Prop</th><th>Typ</th><th>Standard</th><th>Beschreibung</th></tr>
      </thead>
      <tbody>
        <tr><td>links</td><td>Array&lt;&#123;label, href, active?&#125;&gt;</td><td>–</td><td>Navigationspunkte</td></tr>
        <tr><td>currentTeam</td><td>string</td><td>–</td><td>Wird als Sub-Label angezeigt</td></tr>
        <tr><td>class</td><td>string</td><td>–</td><td>Zusätzliche CSS-Klassen</td></tr>
      </tbody>
    </table>
  </div>
</DocsLayout>
