// Demo ICS URL (würde in Produktion aus env kommen)
const demoIcsUrl = 'https://olieder.github.io/bbb-ics-generator/ics/321759_all.ics'

const codeSnippet = `---
import GameSchedule from '@fbnm/design-system/components/GameSchedule/GameSchedule.astro'
import { fetchGamesFromIcal } from '@fbnm/design-system/lib/bbb-ical'

// Daten kommen aus BBB iCal-Feed — wird zur Build-Zeit abgerufen
const games = await fetchGamesFromIcal(
  process.env.ICAL_URL_HERREN,
  'Fibalon Baskets'
)
---

<GameSchedule
  games={games}
  title="Spielplan Herren 1"
  ownTeam="Fibalon Baskets"
  icsUrlAll={process.env.ICAL_URL_HERREN}
/>`
---

<DocsLayout title="Spielplan">
  <div class="docs-page">
    <header class="docs-page__header">
      <p class="docs-page__breadcrumb">Komponenten</p>
      <h1 class="docs-page__title">GameSchedule</h1>
      <p class="docs-page__desc">
        Tabellarischer Spielplan mit Heim/Auswärts-Filterung, Ergebnisanzeige,
        Nächstes-Spiel-Highlight und eingebetteten Kalender-Abonnement-Links
        (iOS, Google Calendar, ICS-Download). Daten kommen aus dem BBB iCal-Feed
        über <code>fetchGamesFromIcal()</code>.
      </p>
    </header>

    <div class="wcag">
      <span class="wcag__icon">✅</span>
      <span>
        Tabs: role="tablist/tab/tabpanel", aria-selected, aria-controls — WCAG 4.1.2 ·
        Aktiver Tab: border-bottom + Farbwechsel (kein Farbe-allein) — WCAG 1.4.1 ·
        Nächstes Spiel: Hintergrund + "Nächstes Spiel"-Label — WCAG 1.4.1 ·
        Badges: Sieg S / Niederlage N mit aria-label — WCAG 1.4.1 ·
        Alle Farben ≥ 7:1 AAA — WCAG 1.4.6 ·
        Touch-Targets ≥ 44px — WCAG 2.5.8
      </span>
    </div>

    <!-- ── Herren 1 ── -->
    <h2 class="docs-heading">Herren 1 — 2. Regionalliga Süd</h2>
    <p class="docs-desc">
      Vollständiger Saisonüberblick: vergangene Spiele (Ergebnis + Sieg/Niederlage),
      nächstes Spiel (hervorgehoben), kommende Spiele mit Uhrzeit und Spielort.
    </p>
    <div class="demo demo--full">
      <GameSchedule
        games={herren1}
        title="Spielplan Herren 1"
        ownTeam="Fibalon Baskets NM"
        icsUrlAll={demoIcsUrl}
        icsUrlHome={demoIcsUrl}
        icsUrlAway={demoIcsUrl}
      />
    </div>

    <!-- ── Herren 2 ── -->
    <h2 class="docs-heading">Herren 2 — Bezirksliga Oberpfalz</h2>
    <p class="docs-desc">
      Gleiche Komponente, andere Instanz — jede Mannschaft bekommt ihr eigenes
      <code>&lt;GameSchedule&gt;</code>.
    </p>
    <div class="demo demo--full">
      <GameSchedule
        games={herren2}
        title="Spielplan Herren 2"
        ownTeam="Fibalon Baskets NM II"
      />
    </div>

    <!-- ── Code ── -->
    <h2 class="docs-heading">Verwendung</h2>
    <div class="code-block">
      <pre set:text={codeSnippet} />
    </div>

    <!-- ── Props ── -->
    <h2 class="docs-heading">Props</h2>
    <table class="props-table">
      <thead>
        <tr><th>Prop</th><th>Typ</th><th>Standard</th><th>Beschreibung</th></tr>
      </thead>
      <tbody>
        <tr><td>games</td><td>ScheduleGame[]</td><td>–</td><td>Spielliste (alle Spiele der Saison)</td></tr>
        <tr><td>title</td><td>string</td><td>'Spielplan'</td><td>Titel im blauen Header</td></tr>
        <tr><td>ownTeam</td><td>string</td><td>'Fibalon Baskets'</td><td>Eigener Teamname — bestimmt Sieg/Niederlage-Auswertung</td></tr>
        <tr><td>icsUrlAll</td><td>string</td><td>–</td><td>ICS-URL für alle Spiele (zeigt Kalender-Abschnitt)</td></tr>
        <tr><td>icsUrlHome</td><td>string</td><td>–</td><td>ICS-URL für Heimspiele</td></tr>
        <tr><td>icsUrlAway</td><td>string</td><td>–</td><td>ICS-URL für Auswärtsspiele</td></tr>
      </tbody>
    </table>

    <!-- ── ScheduleGame type ── -->
    <h2 class="docs-heading">ScheduleGame-Interface</h2>
    <table class="props-table">
      <thead>
        <tr><th>Feld</th><th>Typ</th><th>Pflicht</th><th>Beschreibung</th></tr>
      </thead>
      <tbody>
        <tr><td>uid</td><td>string</td><td>ja</td><td>Eindeutiger Bezeichner (aus iCal UID)</td></tr>
        <tr><td>date</td><td>Date</td><td>ja</td><td>Spieltermin (Datum + Zeit)</td></tr>
        <tr><td>time</td><td>string</td><td>ja</td><td>Uhrzeit als String, z.B. "19:30"</td></tr>
        <tr><td>homeTeam</td><td>string</td><td>ja</td><td>Heimmannschaft</td></tr>
        <tr><td>awayTeam</td><td>string</td><td>ja</td><td>Gastmannschaft</td></tr>
        <tr><td>location</td><td>string</td><td>ja</td><td>Halle / Spielort</td></tr>
        <tr><td>competition</td><td>string</td><td>ja</td><td>Liga oder Pokal</td></tr>
        <tr><td>isHome</td><td>boolean</td><td>ja</td><td>true = Heimspiel aus Vereinssicht</td></tr>
        <tr><td>homeScore</td><td>number</td><td>nein</td><td>Heimtore (bei gespielten Partien)</td></tr>
        <tr><td>awayScore</td><td>number</td><td>nein</td><td>Gasttore (bei gespielten Partien)</td></tr>
      </tbody>
    </table>

    <div class="wcag wcag--info" style="margin-top: var(--fbnm-space-8)">
      <span class="wcag__icon">📅</span>
      <span>
        Die ICS-Feeds werden vom <strong>bbb-ics-generator</strong> erzeugt und enthalten drei Varianten
        pro Mannschaft: alle Spiele (<code>_all.ics</code>), Heimspiele (<code>_home.ics</code>),
        Auswärtsspiele (<code>_away.ics</code>). Abonnenten erhalten Updates automatisch.
      </span>
    </div>
  </div>
</DocsLayout>

<style>
.demo--full { padding: 0; background: none; }
.docs-desc {
  color: var(--fbnm-color-text-muted, #545454);
  font-size: var(--fbnm-text-sm);
  margin: calc(-1 * var(--fbnm-space-4)) 0 var(--fbnm-space-4);
  line-height: 1.6;
}
.wcag--info { background: color-mix(in srgb, var(--fbnm-cyan-500) 8%, white); border-color: var(--fbnm-cyan-500); }
</style>
