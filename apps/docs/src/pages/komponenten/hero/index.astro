---
import DocsLayout from '../../../layouts/DocsLayout.astro'
import Hero from '@ds/components/Hero/Hero.astro'
import Button from '@ds/components/Button/Button.astro'
---

<DocsLayout title="Hero">
  <div class="docs-page">
    <header class="docs-page__header">
      <p class="docs-page__breadcrumb">Komponenten</p>
      <h1 class="docs-page__title">Hero</h1>
      <p class="docs-page__desc">
        Großer Seiteneinstieg mit Display-Headline, optionalem Untertitel und
        Action-Buttons. Hintergrundbild-fähig mit Overlay-Gradient für Lesbarkeit.
      </p>
    </header>

    <div class="wcag">
      <span class="wcag__icon">✅</span>
      <span>
        Titel: weiß auf blue-900-Overlay = 21:1 (AAA) ·
        Subtitle: weiß mit 90% Deckkraft = ~18:1 (AAA) ·
        Cyan-Akzentlinie unten: dekorativ, kein Text ·
        Gradient-Overlay sichert Lesbarkeit auch mit Hintergrundbild.
      </span>
    </div>

    <h2 class="docs-heading">Standard (ohne Bild)</h2>
    <div class="demo">
      <div class="demo__label">Nur Farb-Hintergrund</div>
      <div class="demo__canvas demo__canvas--full">
        <Hero
          title="Willkommen bei den Baskets"
          subtitle="2. Regionalliga Süd · Saison 2024/25"
        >
          <Button variant="primary" href="#">Spielplan</Button>
          <Button variant="ghost" href="#">Mehr erfahren</Button>
        </Hero>
      </div>
    </div>

    <h2 class="docs-heading">Kurze Version (kein Untertitel)</h2>
    <div class="demo">
      <div class="demo__label">Nur Titel + Slot</div>
      <div class="demo__canvas demo__canvas--full">
        <Hero title="Spielplan 2024/25">
          <Button variant="ghost" href="#">iCal herunterladen</Button>
        </Hero>
      </div>
    </div>

    <h2 class="docs-heading">Verwendung</h2>
    <div class="code-block">
      <pre set:text={`---
import Hero from '@fbnm/design-system/components/Hero/Hero.astro'
import Button from '@fbnm/design-system/components/Button/Button.astro'
---

<Hero
  title="Willkommen bei den Baskets"
  subtitle="2. Regionalliga Süd · Saison 2024/25"
  backgroundImage="/images/arena.jpg"
>
  <Button variant="primary" href="/spielplan/">Spielplan</Button>
  <Button variant="ghost"   href="/team/">Unser Team</Button>
</Hero>`} />
    </div>

    <h2 class="docs-heading">Props</h2>
    <table class="props-table">
      <thead>
        <tr><th>Prop</th><th>Typ</th><th>Standard</th><th>Beschreibung</th></tr>
      </thead>
      <tbody>
        <tr><td>title</td><td>string</td><td>–</td><td>Hauptüberschrift (INSOLENT, Uppercase)</td></tr>
        <tr><td>subtitle</td><td>string</td><td>–</td><td>Optionaler Untertitel (Montserrat, weight 300)</td></tr>
        <tr><td>backgroundImage</td><td>string</td><td>–</td><td>URL zum Hintergrundbild</td></tr>
        <tr><td>class</td><td>string</td><td>–</td><td>Zusätzliche CSS-Klassen</td></tr>
        <tr><td>slot</td><td>Astro-Slot</td><td>–</td><td>Button-Gruppe oder andere Inhalte</td></tr>
      </tbody>
    </table>
  </div>
</DocsLayout>
