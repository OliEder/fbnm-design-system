const players = [
  { nr: 5,  name: 'Levin Klemm',   pos: '–', pts: 0,  fgm: 0, ftm: 0, fta: 0 },
  { nr: 6,  name: 'Mona Gaßner',   pos: '–', pts: 0,  fgm: 0, ftm: 0, fta: 0 },
  { nr: 7,  name: 'Lennard Klemm', pos: '–', pts: 10, fgm: 5, ftm: 0, fta: 2, top: true },
