---
import DocsLayout from '../../../layouts/DocsLayout.astro'
import Spielbericht from '@ds/components/Spielbericht/Spielbericht.astro'

// Beispieldaten aus dem Claude-Design-Export "FBNM Spielbericht"
// (U10 vs. DJK Pressath, 15.02.2026).

const periods = [
  { team: 'DJK Pressath',             scores: [14, 8, 8, 6, 13, 8, 14, 16], total: 87 },
  { team: 'Fibalon Baskets Neumarkt', scores: [0, 4, 2, 2, 0, 0, 2, 6],     total: 16, isFBNM: true },
