const standings = [
  { rank: 1, team: 'DJK Pressath',             initials: 'DJK', logoBg: '#1a4b76', games: 10, gp: 20, wins: 10, losses: 0,  gb: '–',   diff: 459 },
  { rank: 2, team: 'Regensburg Baskets 1',     initials: 'RB',  logoBg: '#7a1f1f', games: 11, gp: 18, wins: 9,  losses: 2,  gb: '1.5', diff: 462 },
  { rank: 3, team: 'DJK Neustadt a. d. W. 1',  initials: 'NEU', logoBg: '#494949', games: 11, gp: 16, wins: 8,  losses: 3,  gb: '2.5', diff: 146 },
  { rank: 4, team: 'TB Weiden Basketball',     initials: 'TBW', logoBg: '#14532d', games: 10, gp: 12, wins: 6,  losses: 4,  gb: '4',   diff: -155 },
