---
import DocsLayout from '../../../layouts/DocsLayout.astro'
import Navigation from '@ds/components/Navigation/Navigation.astro'
import Subnav from '@ds/components/Subnav/Subnav.astro'
import Footer from '@ds/components/Footer/Footer.astro'
import GameCard from '@ds/components/GameCard/GameCard.astro'
import MatchStats from '@ds/components/MatchStats/MatchStats.astro'
import LeagueStandings from '@ds/components/LeagueStandings/LeagueStandings.astro'
import GameSchedule from '@ds/components/GameSchedule/GameSchedule.astro'

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Teams', href: '/team/', active: true },
  { label: 'Spielplan', href: '/spielplan/' },
  { label: 'Tabelle', href: '/tabelle/' },
  { label: 'News', href: '/news/' },
  { label: 'Verein', href: '/verein/' },
  { label: 'Kontakt', href: '/kontakt/' },
]
const teamTabs = [
  { label: 'Alle Teams' },
  { label: 'Herren 1', active: true }, { label: 'Herren 2' }, { label: 'Damen', inactive: true },
  { label: 'U20' }, { label: 'U18' }, { label: 'U16' }, { label: 'U14' }, { label: 'U10' },
]

// Reiche Spieltag-Statistik (aus Components-Katalog "Spieltag-Statistik")
const box = [
